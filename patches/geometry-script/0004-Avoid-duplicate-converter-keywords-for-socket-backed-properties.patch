From ebac332fe79a608525b223b88f1a89fb2fe80eb9 Mon Sep 17 00:00:00 2001
From: Meta Vens <rwvens@hotmail.com>
Date: Mon, 4 May 2026 20:04:50 +0100
Subject: [PATCH] Avoid duplicate converter keywords for socket-backed
 properties

---
 operators/convert_tree.py | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/operators/convert_tree.py b/operators/convert_tree.py
index 8485ea2..fa239ab 100644
--- a/operators/convert_tree.py
+++ b/operators/convert_tree.py
@@ -265,6 +265,11 @@ def convert_node_tree(tree):
                     values.append(_convert_value(socket.default_value))
             if not values:
                 continue
+            # Some Blender nodes expose the same conceptual control as both an
+            # RNA enum property and an input socket. Geometry Script maps that
+            # collapsed control to one Python keyword, so prefer the socket
+            # value/link and drop the duplicate property keyword.
+            assignment.props.pop(key, None)
             if len(values) == 1:
                 assignment.arguments[key] = values[0]
                 if output_names:
-- 
